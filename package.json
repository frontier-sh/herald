{
  "name": "herald",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Open-source changelog app powered by Cloudflare Workers",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --mode client && cp -r public/* dist/assets/ 2>/dev/null || true",
    "deploy": "wrangler d1 migrations apply herald-db --remote && wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply herald-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply herald-db --remote"
  },
  "dependencies": {
    "easymde": "^2.18.0",
    "hono": "^4.6.0",
    "marked": "^15.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "@hono/vite-build": "^1.4.0",
    "@hono/vite-dev-server": "^0.19.0",
    "@tailwindcss/vite": "^4.1.18",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.64.0"
  }
}
